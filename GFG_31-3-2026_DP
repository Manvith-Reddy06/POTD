class Solution {
    public int maxProfit(int arr[], int k) {
        // Code here
        int n=arr.length;
        int[][] dp= new int[n][2];
        // dp[i][0] == buy state
        // dp[i][1] == sell state
        dp[0][0]=-1*arr[0];
        dp[0][1]=0;
        for(int i=1;i<n;i++){
            dp[i][0]= Math.max(dp[i-1][0],dp[i-1][1]-arr[i]);
            dp[i][1]= Math.max(dp[i-1][1],dp[i-1][0]+arr[i]-k);
            
        }
        return dp[n-1][1];
    }
}
